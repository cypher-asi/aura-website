# Redirect targets for the site download routes.
DOWNLOAD_MANIFEST_URL=https://cypher-asi.github.io/aura-os/downloads/stable.json
DOWNLOAD_WINDOWS_URL=https://windows-download-host.example/aura-installer.exe
DOWNLOAD_MAC_APPLE_SILICON_URL=https://mac-download-host.example/Aura-Apple-Silicon.dmg
DOWNLOAD_MAC_INTEL_URL=https://mac-download-host.example/Aura-Intel.dmg
DOWNLOAD_LINUX_URL=https://linux-download-host.example/aura.AppImage
DOWNLOAD_FALLBACK_URL=https://downloads.example/aura

# Base URL of the aura-network service. The /roadmap page fetches
# /api/public/feedback here at request time. Use the prod URL for
# both local dev and hosted deploys unless you specifically want to
# read from a local aura-network (e.g. http://localhost:3000).
AURA_NETWORK_URL=https://network.aura.ai

# Fathom Analytics site ID. Leave unset locally to disable tracking.
# Set on the production deploy host to enable visitor analytics.
NEXT_PUBLIC_FATHOM_SITE_ID=
